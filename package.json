{
  "name": "scranbook",
  "version": "0.1.0",
  "description": "A local-first food diary with configurable vision AI.",
  "keywords": [
    "cloudflare-workers",
    "food-diary",
    "indexeddb",
    "lm-studio",
    "local-first",
    "nextjs",
    "openai-compatible",
    "pwa",
    "vision-ai"
  ],
  "homepage": "https://github.com/taugr/scranbook#readme",
  "bugs": {
    "url": "https://github.com/taugr/scranbook/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/scranbook.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "wrangler dev --port 3000",
    "preview": "pnpm build && wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "cloudflare:preview": "pnpm preview",
    "cloudflare:deploy": "pnpm deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "test:live": "tsx scripts/evaluate-live-model.ts",
    "nutrition:data": "tsx scripts/build-nutrition-data.ts",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
