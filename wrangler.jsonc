{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "scranbook",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "scranbook.labs.tau.gr",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./out",
    "html_handling": "force-trailing-slash",
    "not_found_handling": "404-page",
  },
}
